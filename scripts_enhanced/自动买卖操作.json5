    {
      "type": "wait",
      "params": {
        "duration": 0.5
      }
    },
    {
      "type": "log",
      "params": {
        "message": "开始循环点击抬价（买入），直到变为灰色"
      }
    },
    {
      "type": "if_else",
      "params": {
        "condition": "always_true == 'true'",
        "steps": [
          {
            "type": "log",
            "params": {
              "message": "抬价循环（买入） - 需实现检测图片变灰的逻辑"
