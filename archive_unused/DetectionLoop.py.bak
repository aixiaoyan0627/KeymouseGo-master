# -*- encoding:utf-8 -*-
"""
航行检测循环（重构版 - 新主循环逻辑）：
- 主循环：同时检测A和玩家指定海域的所有C类图片
- A循环：持续监测A类图片，存在则点击B类图片，不存在则跳转主循环（带误差弥补）
- C循环：判定海域和城市，执行对应脚本
"""
import os
import time
import random
from dataclasses import dataclass, field
from typing import List, Optional, Tuple, Any, Dict

import numpy as np
import cv2
import json5
from PySide6.QtCore import QThread, Signal, QMutex, QWaitCondition
from loguru import logger

from Util.ImageRecognition import (
    take_screenshot,
    find_image_on_screen,
    click_at,
    get_window_rect_by_title,
)


@dataclass
class IconRule:
    """图标规则：识别到 image_path 时，在 (click_x, click_y) 点击。"""
    image_path: str
    click_x: int
    click_y: int
    threshold: float = 0.8
    button: str = 'left'


def _ruler_to_pixel(region_str: str, width: int, height: int) -> Optional[Tuple[int, int, int, int]]:
    """
    将标尺坐标转换为像素坐标
    格式："起点-终点"，例如 "J36-M39"
    """
    try:
        start, end = region_str.split('-')
        
        # 解析起点
        start_col = ''.join([c for c in start if c.isalpha()])
        start_row = int(''.join([c for c in start if c.isdigit()]))
        
        # 解析终点
        end_col = ''.join([c for c in end if c.isalpha()])
        end_row = int(''.join([c for c in end if c.isdigit()]))
        
        # 计算列索引（A=0, B=1, ..., Z=25, AA=26, AB=27...）
        def col_to_index(col):
            index = 0
            for c in col:
                index = index * 26 + (ord(c.upper()) - ord('A'))
            return index
        
        start_col_idx = col_to_index(start_col)
        end_col_idx = col_to_index(end_col)
        
        # 计算像素坐标
        v_spacing = width / 50  # 50条竖轴
        h_spacing = height / 40  # 40条横轴
        
        left = int(start_col_idx * v_spacing)
        top = int((start_row - 1) * h_spacing)
        right = int((end_col_idx + 1) * v_spacing)
        bottom = int(end_row * h_spacing)
        
        return (left, top, right - left, bottom - top)
    except Exception as e:
        logger.warning('解析标尺坐标失败: {}', e)
        return None

@dataclass
class DetectionConfig:
    """航行检测配置"""
    # A 类图路径列表（imgsA 下全部），检测到则点击位置，不执行脚本
    image_a_paths: List[str] = field(default_factory=list)
    # C 类：始发地海域下全部城市图、中转地海域下全部城市图、回程地海域下全部城市图（每海域一个文件夹，5～15 张不等）
    c_start_sea_paths: List[str] = field(default_factory=list)
    c_transit_sea_paths: List[str] = field(default_factory=list)
    c_back_sea_paths: List[str] = field(default_factory=list)
    # 选中的「处于始发地」「处于中转地」「处于回程地」对应的一张图（匹配到即执行处于脚本，匹配到同海域其它城市执行未处于脚本）
    c_start_path: str = ''
    c_transit_path: str = ''
    c_back_path: str = ''
    script_start_arrived: str = ''
    script_start_not_arrived: str = ''
    script_transit_arrived: str = ''
    script_transit_not_arrived: str = ''
    script_back_arrived: str = ''
    script_back_not_arrived: str = ''
    # imgsC根目录路径，用于获取所有C类图片
    imgsc_root_path: str = ''
    # 兼容旧字段
    trigger_image_paths: List[str] = field(default_factory=list)
    trigger_script_path: str = ''
    icon_rules: List[IconRule] = field(default_factory=list)
    image_a_path: str = ''
    image_b_paths: List[str] = field(default_factory=list)
    script_a_path: str = ''
    script_b_path: str = ''
    use_two_layer: bool = False
    check_interval: float = 0.5
    match_threshold: float = 0.7
    # 游戏窗口标题（部分匹配），非空时只截取该窗口区域，可提高识别率
    capture_window_title: str = ''
    # 流行模式：城市脚本列表
    city_scripts: List[str] = field(default_factory=list)
    # 流行模式：运行模式 - 'single' 单线跑商，'cycle' 搓搓跑商
    popular_mode: str = 'single'
    # 搓搓跑商：主城市（A城市）的多个脚本列表
    main_city_scripts: List[str] = field(default_factory=list)
    # 搓搓跑商：当前主城市脚本索引
    main_city_script_index: int = 0
    # 区域扫描配置：相对于游戏窗口内的坐标 (left, top, width, height)
    # 这些是基于1024x768标准窗口的坐标，会根据实际窗口大小自动缩放
    region_a: Optional[Tuple[int, int, int, int]] = (184, 672, 62, 58)
    region_b: Optional[Tuple[int, int, int, int]] = (560, 450, 180, 180)
    region_c: Optional[Tuple[int, int, int, int]] = (820, 30, 180, 40)
    # 标尺坐标配置（可选）：格式 "起点-终点"，例如 "J36-M39"
    region_a_ruler: Optional[str] = "I36-M40"
    region_b_ruler: Optional[str] = "AD24-AJ30"
    region_c_ruler: Optional[str] = "AP2-AW3"
    # 标准游戏窗口大小（用于坐标缩放参考）
    base_window_width: int = 1024
    base_window_height: int = 768


def _find_first_match(
    paths: List[str],
    screenshot: Any,
    threshold: float,
    capture_offset: Tuple[int, int] = (0, 0),
    region: Optional[Tuple[int, int, int, int]] = None,
) -> Tuple[Optional[str], Optional[Tuple[int, int]]]:
    """在 path 列表中依次匹配，返回第一个匹配到的 (路径, 屏幕中心坐标)，均无则 (None, None)。"""
    for p in paths:
        if not p or not os.path.isfile(p):
            continue
        pos = find_image_on_screen(p, threshold=threshold, screenshot=screenshot, capture_offset=capture_offset, region=region)
        if pos is not None:
            return (p, pos)
    return (None, None)


def _get_all_c_images(imgsc_root: str) -> List[str]:
    """获取imgsC文件夹下所有的C类图片"""
    all_c_paths = []
    if not imgsc_root or not os.path.isdir(imgsc_root):
        return all_c_paths
    
    for sea in os.listdir(imgsc_root):
        sea_dir = os.path.join(imgsc_root, sea)
        if os.path.isdir(sea_dir):
            for f in os.listdir(sea_dir):
                if f.lower().endswith(('.png', '.jpg', '.jpeg')):
                    all_c_paths.append(os.path.join(sea_dir, f))
    return all_c_paths


def _get_sea_name_from_path(image_path: str, imgsc_root: str) -> str:
    """从图片路径中提取海域名称"""
    try:
        rel_path = os.path.relpath(image_path, imgsc_root)
        parts = rel_path.split(os.sep)
        if len(parts) >= 1:
            return parts[0]
    except:
        pass
    return ''


class DetectionLoop(QThread):
    """
    新主循环逻辑：
    - 主循环：同时检测A和玩家指定海域的所有C类图片
    - A循环：持续监测A类图片，存在则点击B类图片
    - C循环：判定海域和城市，执行对应脚本
    """
    trigger_found = Signal(str)
    log_message = Signal(str)

    def __init__(self, config: DetectionConfig, parent=None):
        super().__init__(parent)
        self.config = config
        self._running = True
        self._paused = False
        self._mutex = QMutex()
        self._condition = QWaitCondition()
        # 缩放因子
        self.scale_x = 1.0
        self.scale_y = 1.0
        # 缩放后的区域坐标
        self.scaled_region_a = None
        self.scaled_region_b = None
        self.scaled_region_c = None

    def _calculate_scale_and_regions(self, actual_width: int, actual_height: int):
        """根据实际窗口大小计算缩放因子和缩放后的区域坐标"""
        if actual_width <= 0 or actual_height <= 0:
            self.scale_x = 1.0
            self.scale_y = 1.0
            self.scaled_region_a = self.config.region_a
            self.scaled_region_b = self.config.region_b
            self.scaled_region_c = self.config.region_c
            return
        
        # 计算缩放因子
        self.scale_x = actual_width / self.config.base_window_width
        self.scale_y = actual_height / self.config.base_window_height
        
        # 处理区域坐标
        def get_region(region, ruler_region):
            # 如果提供了标尺坐标，优先使用标尺坐标
            if ruler_region:
                ruler_region_pixel = _ruler_to_pixel(ruler_region, actual_width, actual_height)
                if ruler_region_pixel:
                    return ruler_region_pixel
            # 否则使用原始像素坐标并进行缩放
            if region is None:
                return None
            left, top, width, height = region
            return (
                int(left * self.scale_x),
                int(top * self.scale_y),
                int(width * self.scale_x),
                int(height * self.scale_y)
            )
        
        # 计算各区域坐标
        self.scaled_region_a = get_region(self.config.region_a, self.config.region_a_ruler)
        self.scaled_region_b = get_region(self.config.region_b, self.config.region_b_ruler)
        self.scaled_region_c = get_region(self.config.region_c, self.config.region_c_ruler)
    
    def _draw_ruler(self, screenshot: np.ndarray) -> np.ndarray:
        """
        在截图上画出标尺，包括50条竖轴和40条横轴
        :param screenshot: 截图图像
        :return: 画出标尺后的截图
        """
        try:
            img = screenshot.copy()
            height, width = img.shape[:2]
            
            # 计算间距
            v_spacing = width / 50  # 50条竖轴
            h_spacing = height / 40  # 40条横轴
            
            # 定义颜色：标尺线-浅蓝色，文字-白色
            line_color = (255, 165, 0)  # 浅蓝色 (BGR)
            text_color = (255, 255, 255)  # 白色
            
            # 绘制竖轴（50条）
            for i in range(50):
                x = int(i * v_spacing)
                # 绘制竖线
                cv2.line(img, (x, 0), (x, height), line_color, 1)
                
                # 生成竖轴标签（A-Z, AA-AZ, BA-BZ...）
                label = ''
                num = i
                while num >= 0:
                    label = chr(65 + num % 26) + label  # 65是'A'的ASCII码
                    num = num // 26 - 1
                    if num < 0:
                        break
                
                # 绘制标签
                cv2.putText(img, label, (x + 2, 15), cv2.FONT_HERSHEY_SIMPLEX, 0.4, text_color, 1)
            
            # 绘制横轴（40条）
            for i in range(40):
                y = int(i * h_spacing)
                # 绘制横线
                cv2.line(img, (0, y), (width, y), line_color, 1)
                
                # 绘制标签，确保在图片范围内
                label_y = y - 2 if y > 10 else y + 12
                cv2.putText(img, str(i + 1), (2, label_y), cv2.FONT_HERSHEY_SIMPLEX, 0.4, text_color, 1)
            
            return img
        except Exception as e:
            logger.warning('绘制标尺失败: {}', e)
            return screenshot
    
    def _draw_detection_regions(self, screenshot: np.ndarray, save_path: str = None):
        """
        在截图上画出检测区域的边框
        :param screenshot: 截图图像
        :param save_path: 保存路径，如果为None则不保存
        :return: 画出边框后的截图
        """
        img = screenshot.copy()
        
        # 定义颜色：A类-白色，B类-橙色，C类-红色
        colors = {
            'A': (255, 255, 255),  # 白色
            'B': (0, 165, 255),    # 橙色 (OpenCV是BGR格式)
            'C': (0, 0, 255)       # 红色
        }
        
        # 画出区域A
        if self.scaled_region_a:
            left, top, width, height = self.scaled_region_a
            cv2.rectangle(img, (left, top), (left + width, top + height), colors['A'], 2)
            # 添加标签
            cv2.putText(img, 'A', (left, top - 5), cv2.FONT_HERSHEY_SIMPLEX, 0.6, colors['A'], 2)
        
        # 画出区域B
        if self.scaled_region_b:
            left, top, width, height = self.scaled_region_b
            cv2.rectangle(img, (left, top), (left + width, top + height), colors['B'], 2)
            cv2.putText(img, 'B', (left, top - 5), cv2.FONT_HERSHEY_SIMPLEX, 0.6, colors['B'], 2)
        
        # 画出区域C
        if self.scaled_region_c:
            left, top, width, height = self.scaled_region_c
            cv2.rectangle(img, (left, top), (left + width, top + height), colors['C'], 2)
            cv2.putText(img, 'C', (left, top - 5), cv2.FONT_HERSHEY_SIMPLEX, 0.6, colors['C'], 2)
        
        # 保存图片
        if save_path:
            try:
                # 确保目录存在
                import os
                save_dir = os.path.dirname(save_path)
                if save_dir and not os.path.exists(save_dir):
                    os.makedirs(save_dir, exist_ok=True)
                cv2.imwrite(save_path, img)
                logger.debug('检测区域可视化图片已保存: {}', save_path)
            except Exception as e:
                logger.warning('保存检测区域可视化图片失败: {}', e)
        
        return img

    def stop(self):
        self._running = False
        self._condition.wakeAll()
        if self.isRunning():
            self.wait(2000)

    def resume(self):
        self._mutex.lock()
        self._paused = False
        self._condition.wakeAll()
        self._mutex.unlock()
        logger.debug('DetectionLoop resumed')

    def _run_script_and_wait(self, script_path: str):
        if not script_path or not os.path.isfile(script_path):
            return
        self._paused = True
        self.trigger_found.emit(script_path)
        
        # 真正等待脚本执行完毕
        self._mutex.lock()
        while self._paused and self._running:
            self._condition.wait(self._mutex)
        self._mutex.unlock()

    def _take_screenshot(self):
        """统一的截图函数"""
        try:
            if self.title:
                new_region = get_window_rect_by_title(self.title)
                if new_region:
                    self.capture_region = new_region
            
            if self.capture_region:
                return take_screenshot(region=self.capture_region)
            else:
                return take_screenshot()
        except Exception as e:
            logger.warning('Screenshot failed: {}', e)
            return None, None
    
    def _find_image_with_region(
        self,
        template_path: str,
        threshold: float,
        screenshot: Any,
        capture_offset: Tuple[int, int],
        relative_region: Optional[Tuple[int, int, int, int]] = None
    ) -> Optional[Tuple[int, int]]:
        """
        在指定区域内查找图片（区域相对于游戏窗口，即截图内的坐标）
        
        :param template_path: 模板图片路径
        :param threshold: 匹配阈值
        :param screenshot: 截屏图像（已经是游戏窗口区域）
        :param capture_offset: 截屏偏移
        :param relative_region: 相对于游戏窗口的区域 (left, top, width, height)
        :return: 匹配位置或None
        """
        if relative_region:
            return find_image_on_screen(
                template_path, 
                threshold=threshold, 
                screenshot=screenshot, 
                region=relative_region,
                capture_offset=capture_offset
            )
        else:
            return find_image_on_screen(
                template_path, 
                threshold=threshold, 
                screenshot=screenshot, 
                capture_offset=capture_offset
            )

    def _loop_a(self, a_paths, b_paths, th, interval):
        """
        A循环：持续监测A类图片是否存在
        返回True表示A类图片消失，需要返回主循环
        返回False表示线程停止
        """
        self.log_message.emit('[A循环] 进入A循环 - 航行状态')
        
        # 保险机制：连续检测不到A类图片的次数
        consecutive_miss_count = 0
        max_consecutive_misses = 3  # 连续3次检测不到才认为真的消失了
        
        while self._running:
            if self._paused:
                self._mutex.lock()
                self._condition.wait(self._mutex)
                self._mutex.unlock()
                if not self._running:
                    return False
                continue
            
            screenshot, capture_offset = self._take_screenshot()
            if screenshot is None:
                time.sleep(interval)
                continue
            
            # 检测A类图片
            a_detected = False
            try:
                for path in a_paths:
                    try:
                        pos = find_image_on_screen(path, threshold=th, screenshot=screenshot, capture_offset=capture_offset, region=self.scaled_region_a)
                        if pos is not None:
                            a_detected = True
                            break
                    except Exception as e:
                        logger.warning('Error detecting A class image {}: {}', path, e)
                        continue
            except Exception as e:
                logger.warning('Error in A class detection: {}', e)
            
            if a_detected:
                # 检测到A类图片，重置连续未检测计数
                consecutive_miss_count = 0
                
                # 显示状态并检测B类图片
                self.log_message.emit('正在航行中')
                
                # 检测并点击B类随机图片
                try:
                    for path in b_paths:
                        try:
                            pos = find_image_on_screen(path, threshold=th, screenshot=screenshot, capture_offset=capture_offset, region=self.scaled_region_b)
                            if pos is not None:
                                name = os.path.basename(path)
                                base = os.path.splitext(name)[0]
                                # 反挂机检测：0.5-1.5秒随机延迟
                                random_delay = random.uniform(0.5, 1.5)
                                self.log_message.emit('点击"{}"（延迟{:.2f}秒）'.format(base, random_delay))
                                time.sleep(random_delay)
                                click_at(pos[0], pos[1])
                        except Exception as e:
                            logger.warning('Error detecting B class image {}: {}', path, e)
                            continue
                except Exception as e:
                    logger.warning('Error in B class detection: {}', e)
            else:
                # 未检测到A类图片，增加连续未检测计数
                consecutive_miss_count += 1
                
                if consecutive_miss_count >= max_consecutive_misses:
                    # 连续多次检测不到A类图片，返回主循环
                    self.log_message.emit('[A循环] 离开航行状态，返回主循环')
                    return True
                else:
                    # 单次检测不到，继续等待
                    self.log_message.emit('[A循环] 未检测到航行状态（{}/{}）'.format(consecutive_miss_count, max_consecutive_misses))
            
            time.sleep(interval)
        
        return False

    def _loop_c(self, matched_c_path, c_start_sea, c_transit_sea, c_back_sea, c_start, c_transit, c_back, imgsc_root, th, interval):
        """
        C循环：判定海域和城市，执行对应脚本
        返回True表示脚本执行完毕，返回主循环
        返回False表示线程停止
        """
        script_name = ''
        try:
            # 判定海域
            sea_name = _get_sea_name_from_path(matched_c_path, imgsc_root)
            self.log_message.emit('当前处于「{}」海域'.format(sea_name))
            
            # 判定城市
            city_name = os.path.splitext(os.path.basename(matched_c_path))[0]
            
            # 判定是否处于目标城市
            is_start_city = False
            is_transit_city = False
            is_back_city = False
            target_type = ''
            
            if os.path.normpath(matched_c_path) == os.path.normpath(c_start):
                is_start_city = True
                target_type = '始发地'
                self.log_message.emit('当前所在城市为「{}」，是处于「{}」'.format(city_name, target_type))
                script_path = self.config.script_start_arrived
            elif os.path.normpath(matched_c_path) == os.path.normpath(c_transit):
                is_transit_city = True
                target_type = '中转地'
                self.log_message.emit('当前所在城市为「{}」，是处于「{}」'.format(city_name, target_type))
                script_path = self.config.script_transit_arrived
            elif os.path.normpath(matched_c_path) == os.path.normpath(c_back):
                is_back_city = True
                target_type = '回程地'
                self.log_message.emit('当前所在城市为「{}」，是处于「{}」'.format(city_name, target_type))
                script_path = self.config.script_back_arrived
            else:
                # 检查是在始发地海域、中转地海域还是回程地海域
                in_start_sea = False
                in_transit_sea = False
                in_back_sea = False
                
                for p in c_start_sea:
                    if os.path.normpath(p) == os.path.normpath(matched_c_path):
                        in_start_sea = True
                        break
                
                for p in c_transit_sea:
                    if os.path.normpath(p) == os.path.normpath(matched_c_path):
                        in_transit_sea = True
                        break
                
                for p in c_back_sea:
                    if os.path.normpath(p) == os.path.normpath(matched_c_path):
                        in_back_sea = True
                        break
                
                if in_start_sea:
                    target_type = '始发地'
                    self.log_message.emit('当前所在城市为「{}」，否处于「{}」'.format(city_name, target_type))
                    script_path = self.config.script_start_not_arrived
                elif in_transit_sea:
                    target_type = '中转地'
                    self.log_message.emit('当前所在城市为「{}」，否处于「{}」'.format(city_name, target_type))
                    script_path = self.config.script_transit_not_arrived
                elif in_back_sea:
                    target_type = '回程地'
                    self.log_message.emit('当前所在城市为「{}」，否处于「{}」'.format(city_name, target_type))
                    script_path = self.config.script_back_not_arrived
                else:
                    self.log_message.emit('当前所在城市为「{}」，无法判定海域'.format(city_name))
                    return True
            
            script_name = os.path.basename(script_path) if script_path else '未知脚本'
            
            # 执行脚本
            if script_path and os.path.isfile(script_path):
                self.log_message.emit('[C循环] 开始执行脚本：{}'.format(script_name))
                self.log_message.emit('[C循环] 脚本执行中...')
                self._run_script_and_wait(script_path)
                self.log_message.emit('[C循环] 脚本执行完毕：{}'.format(script_name))
                self.log_message.emit('[C循环] 返回主循环')
            else:
                self.log_message.emit('[C循环] 未找到有效脚本')
            
            return True
        except Exception as e:
            logger.error('Error in C loop: {}', e)
            self.log_message.emit('[C循环] 执行出错')
            return True

    def _main_loop(self, a_paths, b_paths, c_specified_paths, c_all_paths, c_start_sea, c_transit_sea, c_back_sea, c_start, c_transit, c_back, imgsc_root, th, interval):
        """
        主循环：同时检测A和玩家指定海域的所有C类图片
        返回False表示线程停止
        """
        self.log_message.emit('[主循环] 进入主循环')
        
        # 全面检测的开始时间（用于1分钟超时）
        full_detection_start_time = None
        
        while self._running:
            if self._paused:
                self._mutex.lock()
                self._condition.wait(self._mutex)
                self._mutex.unlock()
                if not self._running:
                    return False
                continue
            
            screenshot, capture_offset = self._take_screenshot()
            if screenshot is None:
                time.sleep(interval)
                continue
            
            # 首先检测流行模式
            if self.config.city_scripts:
                script_executed = False
                
                # 搓搓跑商模式
                if self.config.popular_mode == 'cycle' and self.config.main_city_scripts:
                    # 检测是否到达主城市（城市1）
                    main_city_path = self.config.c_start_sea_paths[0] if len(self.config.c_start_sea_paths) > 0 else ''
                    if main_city_path:
                        try:
                            pos = find_image_on_screen(main_city_path, threshold=th, screenshot=screenshot, capture_offset=capture_offset, region=self.scaled_region_c)
                            if pos is not None:
                                # 到达主城市，执行当前索引的脚本
                                current_index = self.config.main_city_script_index
                                main_script_path = self.config.main_city_scripts[current_index] if current_index < len(self.config.main_city_scripts) else ''
                                if main_script_path and os.path.isfile(main_script_path):
                                    city_name = os.path.splitext(os.path.basename(main_city_path))[0]
                                    self.log_message.emit('搓搓跑商：到达主城市「{}」，执行脚本{}/{}'.format(city_name, current_index + 1, len(self.config.main_city_scripts)))
                                    self._run_script_and_wait(main_script_path)
                                    # 更新脚本索引，循环执行
                                    self.config.main_city_script_index = (current_index + 1) % len(self.config.main_city_scripts)
                                    script_executed = True
                        except Exception as e:
                            logger.warning('Error detecting main city image {}: {}', main_city_path, e)
                    
                    # 如果没有在主城市执行脚本，检测副城市（城市2-4）
                    if not script_executed:
                        for i in range(1, len(self.config.city_scripts)):
                            script_path = self.config.city_scripts[i]
                            city_path = self.config.c_start_sea_paths[i] if i < len(self.config.c_start_sea_paths) else ''
                            if script_path and city_path:
                                try:
                                    pos = find_image_on_screen(city_path, threshold=th, screenshot=screenshot, capture_offset=capture_offset, region=self.scaled_region_c)
                                    if pos is not None:
                                        city_name = os.path.splitext(os.path.basename(city_path))[0]
                                        self.log_message.emit('搓搓跑商：到达副城市「{}」，执行对应脚本'.format(city_name))
                                        self._run_script_and_wait(script_path)
                                        script_executed = True
                                        break
                                except Exception as e:
                                    logger.warning('Error detecting city image {}: {}', city_path, e)
                                    continue
                
                # 单线跑商模式（默认）
                else:
                    for i, (script_path, city_path) in enumerate(zip(self.config.city_scripts, self.config.c_start_sea_paths)):
                        if script_path and city_path:
                            try:
                                pos = find_image_on_screen(city_path, threshold=th, screenshot=screenshot, capture_offset=capture_offset, region=self.scaled_region_c)
                                if pos is not None:
                                    city_name = os.path.splitext(os.path.basename(city_path))[0]
                                    self.log_message.emit('单线跑商：当前城市「{}」，执行对应脚本'.format(city_name))
                                    self._run_script_and_wait(script_path)
                                    script_executed = True
                                    break
                            except Exception as e:
                                logger.warning('Error detecting city image {}: {}', city_path, e)
                                continue
                
                if script_executed:
                    full_detection_start_time = None
                    time.sleep(interval)
                    continue
            
            # 远洋模式：同时检测A和指定海域的C类图片
            a_detected = False
            matched_c_specified = None
            
            # 检测A类图片
            try:
                for path in a_paths:
                    try:
                        pos = find_image_on_screen(path, threshold=th, screenshot=screenshot, capture_offset=capture_offset, region=self.scaled_region_a)
                        if pos is not None:
                            a_detected = True
                            break
                    except Exception as e:
                        logger.warning('Error detecting A class image {}: {}', path, e)
                        continue
            except Exception as e:
                logger.warning('Error in A class detection: {}', e)
            
            # 检测指定海域的C类图片
            if c_specified_paths:
                try:
                    matched_c_specified, _ = _find_first_match(c_specified_paths, screenshot, th, capture_offset, region=self.scaled_region_c)
                except Exception as e:
                    logger.warning('Error detecting specified C images: {}', e)
            
            # 判断状态
            if a_detected:
                # 检测到A类图片，进入A循环
                full_detection_start_time = None
                self.log_message.emit('[主循环] 检测到航行状态，进入A循环')
                go_to_main = self._loop_a(a_paths, b_paths, th, interval)
                if not go_to_main:
                    return False
            elif matched_c_specified is not None:
                # 检测到指定海域的C类图片，进入C循环
                full_detection_start_time = None
                self.log_message.emit('[主循环] 检测到城市，进入C循环')
                go_to_main = self._loop_c(matched_c_specified, c_start_sea, c_transit_sea, c_back_sea, c_start, c_transit, c_back, imgsc_root, th, interval)
                if not go_to_main:
                    return False
            else:
                # 都检测不到，开始全面检测（1分钟超时）
                if full_detection_start_time is None:
                    full_detection_start_time = time.time()
                    self.log_message.emit('[主循环] 未检测到目标，开始全面检测（1分钟超时）...')
                
                # 计算已过时间
                elapsed_time = time.time() - full_detection_start_time
                
                matched_all_c = None
                a_detected_all = False
                
                # 再次检测A类图片
                try:
                    for path in a_paths:
                        try:
                            pos = find_image_on_screen(path, threshold=th, screenshot=screenshot, capture_offset=capture_offset, region=self.scaled_region_a)
                            if pos is not None:
                                a_detected_all = True
                                break
                        except Exception as e:
                            logger.warning('Error detecting A class image (all): {}', path, e)
                            continue
                except Exception as e:
                    logger.warning('Error in A class detection (all): {}', e)
                
                # 检测所有C类图片
                if c_all_paths:
                    try:
                        matched_all_c, _ = _find_first_match(c_all_paths, screenshot, th, capture_offset, region=self.scaled_region_c)
                    except Exception as e:
                        logger.warning('Error detecting all C images: {}', e)
                
                if a_detected_all:
                    # 检测到A类图片，进入A循环
                    full_detection_start_time = None
                    self.log_message.emit('[主循环] 全面检测到航行状态，进入A循环')
                    go_to_main = self._loop_a(a_paths, b_paths, th, interval)
                    if not go_to_main:
                        return False
                elif matched_all_c is not None:
                    # 检测到玩家在指定海域以外的城市
                    full_detection_start_time = None
                    sea_name = _get_sea_name_from_path(matched_all_c, imgsc_root)
                    city_name = os.path.splitext(os.path.basename(matched_all_c))[0]
                    self.log_message.emit('检测到玩家在「{}」海域「{}」，已超出指定范围，停止航行'.format(sea_name, city_name))
                    self._running = False
                    return False
                else:
                    # 检查是否超时（1分钟）
                    if elapsed_time >= 60:
                        self.log_message.emit('地点检测异常（1分钟超时），停止航行')
                        self._running = False
                        return False
                    else:
                        remaining = int(60 - elapsed_time)
                        self.log_message.emit('[主循环] 继续全面检测中...（剩余{}秒）'.format(remaining))
            
            time.sleep(interval)
        
        return False

    def run(self):
        try:
            logger.info('DetectionLoop started')
            interval = max(self.config.check_interval, 0.3)
            th = self.config.match_threshold
            
            # 开始前静默 5 秒，等待玩家把游戏窗口切到最前
            time.sleep(5.0)
            
            # 默认锁定游戏窗口，仅在该窗口内识别；锁定失败则直接停止
            self.capture_region = None
            self.title = (self.config.capture_window_title or '').strip()
            if self.title:
                self.capture_region = get_window_rect_by_title(self.title)
                if self.capture_region:
                    self.log_message.emit('[航行] 已锁定游戏窗口「{}」，仅在该窗口内识别'.format(self.title))
                    # 根据游戏窗口大小计算缩放因子和缩放后的区域坐标
                    window_width, window_height = self.capture_region[2], self.capture_region[3]
                    self._calculate_scale_and_regions(window_width, window_height)
                    self.log_message.emit('[航行] 游戏窗口大小: {}x{}, 缩放因子: {:.2f}x{:.2f}'.format(
                        window_width, window_height, self.scale_x, self.scale_y))
                    
                    # 保存检测区域可视化图片
                    screenshot, capture_offset = self._take_screenshot()
                    if screenshot is not None:
                        import datetime
                        timestamp = datetime.datetime.now().strftime('%Y%m%d_%H%M%S')
                        
                        try:
                            # 保存带标尺的图片
                            ruler_save_path = os.path.join('logs', f'ruler_{timestamp}.png')
                            ruler_img = self._draw_ruler(screenshot)
                            try:
                                # 确保目录存在
                                save_dir = os.path.dirname(ruler_save_path)
                                if save_dir and not os.path.exists(save_dir):
                                    os.makedirs(save_dir, exist_ok=True)
                                cv2.imwrite(ruler_save_path, ruler_img)
                                logger.debug('标尺图片已保存: {}', ruler_save_path)
                                self.log_message.emit('[航行] 标尺图片已保存到: {}'.format(ruler_save_path))
                            except Exception as e:
                                logger.warning('保存标尺图片失败: {}', e)
                        except Exception as e:
                            logger.warning('生成标尺图片失败: {}', e)
                        
                        try:
                            # 保存检测区域图片
                            save_path = os.path.join('logs', f'detection_regions_{timestamp}.png')
                            self._draw_detection_regions(screenshot, save_path)
                            self.log_message.emit('[航行] 检测区域可视化图片已保存到: {}'.format(save_path))
                        except Exception as e:
                            logger.warning('保存检测区域图片失败: {}', e)
                else:
                    self.log_message.emit('[航行] 未找到游戏窗口「{}」，航行已停止，请确认游戏已打开且处于前台'.format(self.title))
                    logger.warning('DetectionLoop stopped because game window not found: {}', self.title)
                    return
            else:
                # 如果没有指定游戏窗口标题，使用默认缩放因子
                self._calculate_scale_and_regions(self.config.base_window_width, self.config.base_window_height)
            
            # 初始化图片路径
            c_start_sea = [p for p in self.config.c_start_sea_paths if p and os.path.isfile(p)]
            c_transit_sea = [p for p in self.config.c_transit_sea_paths if p and os.path.isfile(p)]
            c_back_sea = [p for p in self.config.c_back_sea_paths if p and os.path.isfile(p)]
            c_start = os.path.normpath(self.config.c_start_path) if self.config.c_start_path and os.path.isfile(self.config.c_start_path) else ''
            c_transit = os.path.normpath(self.config.c_transit_path) if self.config.c_transit_path and os.path.isfile(self.config.c_transit_path) else ''
            c_back = os.path.normpath(self.config.c_back_path) if self.config.c_back_path and os.path.isfile(self.config.c_back_path) else ''
            a_paths = [p for p in self.config.image_a_paths if p and os.path.isfile(p)]
            b_paths = [p for p in self.config.image_b_paths if p and os.path.isfile(p)]
            
            # 获取指定海域的所有C类图片
            c_specified_paths = []
            c_specified_paths.extend(c_start_sea)
            c_specified_paths.extend(c_transit_sea)
            c_specified_paths.extend(c_back_sea)
            
            # 获取所有C类图片
            c_all_paths = _get_all_c_images(self.config.imgsc_root_path)
            
            # 调试日志
            logger.debug('A类图片路径: {}', a_paths)
            logger.debug('B类图片路径: {}', b_paths)
            logger.debug('C类指定海域图片路径: {}', c_specified_paths)
            logger.debug('C类所有图片数量: {}', len(c_all_paths))
            logger.debug('C类始发地图片路径: {}', c_start)
            logger.debug('C类中转地图片路径: {}', c_transit)
            logger.debug('C类回程地图片路径: {}', c_back)
            logger.debug('匹配阈值: {}', th)
            logger.debug('检测间隔: {}秒', interval)
            
            # 进入主循环
            self._main_loop(a_paths, b_paths, c_specified_paths, c_all_paths, c_start_sea, c_transit_sea, c_back_sea, c_start, c_transit, c_back, self.config.imgsc_root_path, th, interval)
            
            logger.info('DetectionLoop stopped')
        except Exception as e:
            logger.error('Critical error in DetectionLoop: {}', e)
            self._running = False
            try:
                self.log_message.emit('检测线程发生错误，已停止')
            except:
                pass


def _resolve_path(path: str, base_dir: str) -> str:
    if os.path.isabs(path):
        return path
    return os.path.normpath(os.path.join(base_dir, path))


def load_config(config_path: str, base_dir: Optional[str] = None) -> Optional[DetectionConfig]:
    """从 JSON5 加载配置。"""
    if not os.path.isfile(config_path):
        logger.warning('Config file not found: {}', config_path)
        return None
    try:
        with open(config_path, 'r', encoding='utf-8') as f:
            data = json5.load(f)
    except Exception as e:
        logger.error('Failed to load config: {}', e)
        return None

    base = base_dir or os.path.dirname(os.path.abspath(config_path))
    trigger_paths = data.get('trigger_image_paths', [])
    if isinstance(trigger_paths, str):
        trigger_paths = [trigger_paths]
    trigger_paths = [_resolve_path(p, base) for p in trigger_paths]
    trigger_script = _resolve_path(data.get('trigger_script_path', ''), base)
    icon_rules = []
    for r in data.get('icon_rules', []):
        if isinstance(r, dict) and r.get('image_path'):
            icon_rules.append(IconRule(
                image_path=_resolve_path(r['image_path'], base),
                click_x=int(r.get('click_x', 0)),
                click_y=int(r.get('click_y', 0)),
                threshold=float(r.get('threshold', 0.8)),
                button=str(r.get('button', 'left')),
            ))
    image_a_paths: List[str] = []
    imgs_a = _resolve_path(data.get('imgsA_folder', 'imgsA'), base)
    if os.path.isdir(imgs_a):
        for f in os.listdir(imgs_a):
            if f.lower().endswith(('.png', '.jpg', '.jpeg')):
                image_a_paths.append(os.path.join(imgs_a, f))
    c_start = _resolve_path(data.get('c_start_path', ''), base) or ''
    c_back = _resolve_path(data.get('c_back_path', ''), base) or ''
    start_arr = _resolve_path(data.get('script_start_arrived', ''), base) or ''
    start_not = _resolve_path(data.get('script_start_not_arrived', ''), base) or ''
    back_arr = _resolve_path(data.get('script_back_arrived', ''), base) or ''
    back_not = _resolve_path(data.get('script_back_not_arrived', ''), base) or ''

    return DetectionConfig(
        trigger_image_paths=trigger_paths,
        trigger_script_path=trigger_script,
        icon_rules=icon_rules,
        image_a_paths=image_a_paths,
        image_a_path='',
        image_b_paths=[],
        c_start_path=c_start,
        c_back_path=c_back,
        script_start_arrived=start_arr,
        script_start_not_arrived=start_not,
        script_back_arrived=back_arr,
        script_back_not_arrived=back_not,
        script_a_path='',
        script_b_path='',
        use_two_layer=False,
        check_interval=float(data.get('check_interval', 0.5)),
        match_threshold=float(data.get('match_threshold', 0.8)),
        region_a_ruler=data.get('region_a_ruler', "I36-M40"),
        region_b_ruler=data.get('region_b_ruler', "AD24-AJ30"),
        region_c_ruler=data.get('region_c_ruler', "AP2-AW3"),
    )


def list_sea_city_from_imgsc(imgsc_dir: str) -> Dict[str, List[str]]:
    """imgsC/海域名/城市名.png → {"海域名": ["城市名", ...]}。支持中文文件名。"""
    out: Dict[str, List[str]] = {}
    if not os.path.isdir(imgsc_dir):
        return out
    for sea in os.listdir(imgsc_dir):
        full = os.path.join(imgsc_dir, sea)
        if not os.path.isdir(full):
            continue
        cities = []
        for f in os.listdir(full):
            if f.lower().endswith(('.png', '.jpg', '.jpeg')):
                cities.append(os.path.splitext(f)[0])
        if cities:
            out[sea] = sorted(cities)
    return out


def get_c_image_path(imgsc_dir: str, sea: str, city: str) -> str:
    """根据海域、城市名得到 C 类图路径。支持中文文件名。"""
    if not sea or not city:
        return ''
    folder = os.path.join(imgsc_dir, sea)
    for ext in ('.png', '.jpg', '.jpeg'):
        p = os.path.join(folder, city + ext)
        if os.path.isfile(p):
            return p
    return ''
